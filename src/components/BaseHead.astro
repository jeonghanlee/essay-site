---
import {
  absoluteUrl,
  DEFAULT_HERO_IMAGE,
  pathWithBase,
  SITE_DESCRIPTION,
  SITE_TITLE,
  UI_COPY,
} from "../lib/site";

type AlternateLink = {
  lang: string;
  path: string;
};

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  path?: string;
  image?: string;
  alternates?: AlternateLink[];
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  lang = "en",
  path = "/",
  image = DEFAULT_HERO_IMAGE,
  alternates = [],
} = Astro.props;

const language = lang === "ko" ? "ko" : "en";
const siteTitle = UI_COPY[language].siteTitle;
const pageTitle = title === SITE_TITLE ? siteTitle : `${title} | ${siteTitle}`;
const canonical = absoluteUrl(path, Astro.site);
const imageUrl = absoluteUrl(image, Astro.site);
const locale = language === "ko" ? "ko_KR" : "en_US";
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" />
{language === "ko" && (
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;600;700&display=swap" />
)}
<link rel="canonical" href={canonical} />
<link rel="alternate" type="application/rss+xml" title={`${siteTitle} RSS`} href={pathWithBase("/rss.xml")} />
<link rel="alternate" type="application/rss+xml" title={UI_COPY[language].koRss} href={pathWithBase("/rss/ko.xml")} />
<link rel="alternate" type="application/rss+xml" title={UI_COPY[language].enRss} href={pathWithBase("/rss/en.xml")} />
{alternates.map((alternate) => <link rel="alternate" hreflang={alternate.lang} href={absoluteUrl(alternate.path, Astro.site)} />)}
<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta property="og:locale" content={locale} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
