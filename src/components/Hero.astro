---
import { DEFAULT_HERO_IMAGE, pathWithBase } from "../lib/site";
---

<section class="hero" aria-labelledby="hero-title">
  <img class="hero-image" src={pathWithBase(DEFAULT_HERO_IMAGE)} alt="" loading="eager" decoding="async" />
  <div class="hero-content">
    <p class="eyebrow">Essay Archive</p>
    <h1 id="hero-title">What survives forgetting.</h1>
    <p>
      Written with an agent, kept in a human hand — on memory, forgetting, and what endures.
    </p>
    <div class="hero-actions" aria-label="Archive selection">
      <a href={pathWithBase("/en/")}>EN</a>
      <a href={pathWithBase("/ko/")}>KO</a>
    </div>
  </div>
</section>
